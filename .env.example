# ============================================================================
# Fintrk — environment variables.
#
# Copy this file to .env.local and fill in your own values.
# Never commit .env.local to version control.
# ============================================================================

# --- Core (required) --------------------------------------------------------

# PostgreSQL connection string. Recommended provider: Neon (https://console.neon.tech)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# JWT session secret. Generate with: openssl rand -base64 48
# Rotating this invalidates all active sessions.
JWT_SECRET=

# Bearer token Vercel Cron uses to call /api/cron/*. Generate with: openssl rand -base64 48
CRON_SECRET=

# OpenAI API key for statement parsing and AI categorization.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Owner identity (shown in /privacy and /terms) --------------------------

# Your name (legal data controller for GDPR purposes).
NEXT_PUBLIC_OWNER_NAME=

# City, Country (jurisdiction for terms of service).
NEXT_PUBLIC_OWNER_LOCATION=

# Owner contact email (privacy policy data controller).
NEXT_PUBLIC_OWNER_EMAIL=

# Support email (user-facing).
NEXT_PUBLIC_SUPPORT_EMAIL=

# Public app origin used in metadata, email links, and same-origin checks.
# Example: https://app.example.com
NEXT_PUBLIC_APP_URL=

# --- Observability (optional, recommended in prod) --------------------------

# Sentry DSN (https://sentry.io). Without this, errors go to console + Vercel logs only.
SENTRY_DSN=

# --- Email (optional) -------------------------------------------------------

# Resend API key for welcome / transactional emails (https://resend.com).
RESEND_API_KEY=

# If set, /api/report-import-error sends a copy of import errors to this address.
# Otherwise reports are stored in DB only.
IMPORT_ERROR_REPORT_TO=

# --- Security (optional) ----------------------------------------------------

# Comma-separated list of allowed origins for CORS.
# Example: ALLOWED_ORIGINS=mydomain.com,www.mydomain.com
ALLOWED_ORIGINS=

# --- AI model overrides (optional) ------------------------------------------

# Defaults: gpt-4o (vision/parse), gpt-4o-mini (categorize).
# FINTRK_AI_VISION_MODEL=
# FINTRK_AI_PARSE_MODEL=
# FINTRK_AI_CATEGORIZE_MODEL=
